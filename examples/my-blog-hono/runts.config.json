{
  "server": {
    "port": 8000,
    "host": "127.0.0.1"
  },
  "build": {
    "target": "rust",
    "optimization": {
      "lto": true,
      "opt_level": "z"
    },
    "parallel": true,
    "incremental": true
  },
  "islands": {
    "hydration": "visible",
    "serializer": "json"
  },
  "dev": {
    "port": 8000,
    "open": false,
    "hmr": true
  },
  "watch": {
    "ignored": [
      "**/node_modules/**",
      "**/target/**",
      "**/.git/**"
    ],
    "include": [
      "routes/**",
      "islands/**",
      "components/**"
    ]
  }
}
