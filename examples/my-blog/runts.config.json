{
  "$schema": "https://runts.dev/schema.json",
  "name": "my-blog",
  "version": "0.1.0",
  "description": "A Fresh/Preact blog built with runts",
  
  "server": {
    "host": "0.0.0.0",
    "port": 8000
  },
  
  "islands": {
    "hydration": "lazy",
    "serializer": "json"
  },
  
  "build": {
    "optimization": {
      "lto": true,
      "opt_level": "z"
    }
  },
  
  "dev": {
    "port": 8000,
    "open": true,
    "hmr": true
  },
  
  "watch": {
    "ignored": ["**/node_modules/**", "**/target/**", "**/.git/**"]
  }
}
